<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage"
    BackgroundColor="#F5F5F5">

    <Grid>

        <!-- MAP -->
        <maps:Map
            x:Name="Map"
            IsShowingUser="True"
            MapType="Street" />

        <!-- TOP BAR -->
        <Border
            Margin="16,50,16,0"
            Padding="10"
            BackgroundColor="#FFFFFFEE"
            StrokeShape="RoundRectangle 20"
            VerticalOptions="Start">

            <HorizontalStackLayout Spacing="10">

                <Button Text="VIETNAM"
                        WidthRequest="50"
                        HeightRequest="40"
                        CornerRadius="12"
                        BackgroundColor="#EEEEEE"
                        Clicked="OnVietnameseClicked"/>

                <Button Text="ENGLISH"
                        WidthRequest="50"
                        HeightRequest="40"
                        CornerRadius="12"
                        BackgroundColor="#EEEEEE"
                        Clicked="OnEnglishClicked"/>

                <Label Text="Audio Guide"
                       VerticalOptions="Center"
                       FontAttributes="Bold"
                       FontSize="16"
                       TextColor="#333"/>
            </HorizontalStackLayout>
        </Border>

        <!-- BOTTOM PANEL -->
        <Border
    x:Name="BottomPanel"
    IsVisible="{Binding IsPoiPanelVisible}"
    VerticalOptions="End"
    Margin="16,0,16,20"
    Padding="0"
    BackgroundColor="White"
    StrokeShape="RoundRectangle 25">

            <Border.Shadow>
                <Shadow Brush="Black"
                Opacity="0.2"
                Offset="0,4"
                Radius="12"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto">

                <!-- HANDLE -->
                <BoxView HeightRequest="4"
                 WidthRequest="40"
                 CornerRadius="2"
                 BackgroundColor="#CCCCCC"
                 HorizontalOptions="Center"
                 Margin="0,10"/>

                <!-- CONTENT -->
                <VerticalStackLayout
            Grid.Row="1"
            Padding="20"
            Spacing="10">

                    <Label Text="{Binding SelectedPoi.Name}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#111"/>

                    <Label Text="{Binding SelectedPoi.NarrationShort}"
                   FontSize="14"
                   TextColor="#666"
                   MaxLines="3"
                   LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>

                <!-- ACTIONS -->
                <Grid Grid.Row="2"
              Padding="15"
              ColumnDefinitions="*,*"
              ColumnSpacing="10">

                    <Button Text="▶ Nghe chi tiết"
                    BackgroundColor="#007AFF"
                    TextColor="White"
                    CornerRadius="15"
                    HeightRequest="45"
                    Clicked="OnListenDetailedClicked"/>

                    <Button Grid.Column="1"
                    Text="✕ Đóng"
                    BackgroundColor="#EEEEEE"
                    TextColor="#333"
                    CornerRadius="15"
                    HeightRequest="45"
                    Clicked="OnClosePanelClicked"/>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</ContentPage>